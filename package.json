{
  "name": "alexspirgel.github.io",
  "version": "1.0.0",
  "description": "My personal portfolio.",
  "main": "index.js",
  "scripts": {
    "scripts": "esbuild ./scripts/src/header.js ./scripts/src/footer.js --outdir=./scripts/dist/ --bundle --minify --sourcemap --watch",
    "styles": "sass ./styles/src/index.scss ./styles/dist/styles.css --style=compressed --watch",
    "build": "concurrently --kill-others --raw \"npm run scripts\" \"npm run styles\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexspirgel/alexspirgel.github.io.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alexspirgel/alexspirgel.github.io/issues"
  },
  "homepage": "https://github.com/alexspirgel/alexspirgel.github.io#readme",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "esbuild": "0.28.0",
    "sass": "^1.99.0"
  },
  "dependencies": {
    "@alexspirgel/no-scroll": "^1.0.2",
    "@alexspirgel/transition-auto": "^2.0.6",
    "micromodal": "^0.6.1"
  }
}
